{
  "name": "chasm",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "dev:api": "go run ./apps/api/cmd/server",
    "build:api": "go build -o ./bin/chasm-api.exe ./apps/api/cmd/server",
    "test:api": "go test ./apps/api/..."
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
